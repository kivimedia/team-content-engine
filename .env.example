# Database
TCE_DATABASE_URL=postgresql+asyncpg://tce:tce@localhost:5432/tce

# Anthropic
TCE_ANTHROPIC_API_KEY=sk-ant-...

# Models (defaults shown)
TCE_DEFAULT_MODEL=claude-sonnet-4-20250514
TCE_OPUS_MODEL=claude-opus-4-20250514
TCE_HAIKU_MODEL=claude-haiku-4-5-20251001

# Budget controls
TCE_DAILY_BUDGET_USD=40.00
TCE_MONTHLY_BUDGET_USD=800.00

# fal.ai
TCE_FAL_API_KEY=

# Logging
TCE_LOG_LEVEL=INFO

# Server
TCE_HOST=0.0.0.0
TCE_PORT=8000

# Web search (Brave Search API)
TCE_SEARCH_API_KEY=

# S3-compatible storage
TCE_S3_ENDPOINT=
TCE_S3_BUCKET=tce-assets
TCE_S3_ACCESS_KEY=
TCE_S3_SECRET_KEY=

# Social platform tokens (for CTA fulfillment)
TCE_FACEBOOK_PAGE_TOKEN=
TCE_FACEBOOK_VERIFY_TOKEN=tce_webhook_verify
TCE_LINKEDIN_ACCESS_TOKEN=

# Notifications
TCE_RESEND_API_KEY=
TCE_SLACK_WEBHOOK_URL=
TCE_NOTIFICATION_EMAIL=

# Per-agent cost cap
TCE_PER_AGENT_DAILY_CAP_USD=10.00

# Video rendering (Remotion)
TCE_REMOTION_PROJECT_PATH=
TCE_VIDEO_OUTPUT_DIR=
TCE_VIDEO_DEFAULT_CODEC=h264
TCE_VIDEO_MAX_RENDER_SECONDS=120

# OpenAI (Whisper alignment for narrated video)
TCE_OPENAI_API_KEY=sk-...
